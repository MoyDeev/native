{
  "name": "project-native-federation",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "concurrently --names \"SHELL,P1,P2,NATIVE,NATIVE-TWO\" --prefix-colors \"blue,green,yellow,magenta\" \"ng serve --no-ssr --port 4200\" \"ng serve plugin-one --no-ssr --port 4201\" \"ng serve plugin-two --no-ssr --port 4202\" \"cd ../project-native && ng serve --no-ssr --port 4203\" \"cd ../project-native-two && ng serve --no-ssr --port 4204\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:project-native-federation": "node dist/project-native-federation/server/server.mjs",
    "serve:ssr:plugin-one": "node dist/plugin-one/server/server.mjs",
    "serve:ssr:plugin-two": "node dist/plugin-two/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-server": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/ssr": "^21.2.2",
    "@softarc/native-federation-node": "^3.3.4",
    "cors": "^2.8.5",
    "es-module-shims": "^1.5.12",
    "express": "^5.1.0",
    "library-ui": "^0.0.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.2.1",
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.19",
    "concurrently": "^9.2.1",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.2.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
